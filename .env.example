# Bot token (xoxb-...) — from OAuth & Permissions after installing the app
SLACK_BOT_TOKEN=xoxb-your-token

# App-level token (xapp-...) with connections:write — from Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-your-token

# --- Access control (recommended) ---

# Comma-separated Slack user IDs allowed to use the bot (and click approval buttons).
# Empty = everyone in the workspace. Find your ID: profile > three dots > Copy member ID.
#SLACK_ALLOWED_USERS=U0123ABCDEF

# --- Claude Code options (all optional) ---

# Path to the claude binary (default: "claude" on PATH)
#CLAUDE_BIN=claude

# Default working directory Claude sessions run in (default: ./workspace next to bot.py)
#CLAUDE_CWD=/Users/you/some/project

# Per-channel working directories: JSON mapping of channel ID or name -> path.
# Threads started in that channel run Claude in that directory.
#CLAUDE_CHANNEL_DIRS={"myapp": "~/code/myapp", "C0123ABCDEF": "~/code/other"}

# Model alias or full name (default: whatever your claude CLI defaults to).
# Can be overridden per-thread with !model.
#CLAUDE_MODEL=opus

# Permissions:
#   skip  (default) = --dangerously-skip-permissions: full autonomy, no prompts
#   slack           = every non-trivial tool call posts Approve/Deny buttons in the thread
#   gated           = plain --permission-mode (below); anything it would prompt for is denied
#CLAUDE_APPROVAL_MODE=skip

# Only used when CLAUDE_APPROVAL_MODE=gated:
#CLAUDE_PERMISSION_MODE=acceptEdits

# Localhost port for the bot's HTTP server (approval hook + session events)
#APPROVAL_PORT=8787

# Only used when CLAUDE_APPROVAL_MODE=slack:
#APPROVAL_TIMEOUT=300            # seconds to wait for a button click before denying
#APPROVAL_AUTO_ALLOW=Read,Glob,Grep,Task,TodoWrite,WebFetch,WebSearch,NotebookRead

# Terminal handoff: when a thread is checked out (!terminal), Slack messages are
# held with a warning. Set to 1 to make Slack win instead: an incoming message
# force-closes the live terminal session and runs immediately.
#HANDOFF_SLACK_WINS=0

# Channel (or DM channel ID) where terminal-started sessions (bin/silkworm) get
# their Slack anchor thread. Defaults to the bot's most recently used DM.
#SILKWORM_HOME_CHANNEL=D0123ABCDEF

# Extra args appended to every claude invocation, e.g. --allowedTools "Bash(git *) Read"
#CLAUDE_EXTRA_ARGS=

# Per-message timeout in seconds (default 900 = 15 min)
#CLAUDE_TIMEOUT=900

# Cheap model used to auto-title new threads after their first turn
# (shown in the visualizer and !sessions). Empty string disables.
#NAMING_MODEL=haiku

# Forget thread sessions untouched for this many days (default 30)
#SESSION_MAX_AGE_DAYS=30
