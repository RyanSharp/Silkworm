{
    "display_information": {
        "name": "Silkworm",
        "description": "Spins a Claude Code session for every Slack thread",
        "background_color": "#1f1f1f"
    },
    "features": {
        "app_home": {
            "messages_tab_enabled": true,
            "messages_tab_read_only_enabled": false
        },
        "bot_user": {
            "display_name": "silkworm",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "app_mentions:read",
                "chat:write",
                "im:history",
                "im:read",
                "im:write",
                "reactions:read",
                "reactions:write",
                "files:read",
                "files:write",
                "channels:history",
                "groups:history",
                "mpim:history",
                "channels:read",
                "groups:read",
                "users:read"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.im"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}
